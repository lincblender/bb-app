import pgvector
from pgvector import PGVector
from pgvector.models import PGVectorModel
from django.db import models
from django.contrib.auth.models import User
from django.db.models.signals import post_save
from django.dispatch import receiver

# Define models for Tier 1 prime contractors and SMEs
class Tier1PrimeContractor(models.Model):
    name = models.CharField(max_length=255)
    capabilities = PGVectorField(dimensions=2)

class SME(models.Model):
    name = models.CharField(max_length=255)
    capabilities = PGVectorField(dimensions=2)

# Define a model for bounties
class Bounty(models.Model):
    title = models.CharField(max_length=255)
    description = models.TextField()
    reward = models.DecimalField(max_digits=10, decimal_places=2)
    tier1_prime_contractor = models.ForeignKey(Tier1PrimeContractor, on_delete=models.CASCADE)
    sme = models.ForeignKey(SME, on_delete=models.CASCADE, null=True, blank=True)

# Define a model for teaming retainers
class TeamingRetainer(models.Model):
    title = models.CharField(max_length=255)
    description = models.TextField()
    retainer = models.DecimalField(max_digits=10, decimal_places=2)
    tier1_prime_contractor = models.ForeignKey(Tier1PrimeContractor, on_delete=models.CASCADE)
    sme = models.ForeignKey(SME, on_delete=models.CASCADE, null=True, blank=True)

# Define a function to calculate the similarity between two vectors
def calculate_similarity(vector1, vector2):
    return pgvector.similarity(vector1, vector2)

# Define a function to recommend matches between Tier 1 prime contractors and SMEs
def recommend_matches(tier1_prime_contractor):
    sme_vectors = SME.objects.all().values_list('capabilities', flat=True)
    similarities = []
    for sme_vector in sme_vectors:
        similarity = calculate_similarity(tier1_prime_contractor.capabilities, sme_vector)
        similarities.append((sme_vector, similarity))
    similarities.sort(key=lambda x: x[1], reverse=True)
    return similarities

