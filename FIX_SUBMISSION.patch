# Define a view to handle Stripe checkout
from django.http import HttpResponseRedirect
from django.views.decorators.csrf import csrf_exempt

@csrf_exempt
def stripe_checkout(request):
    if request.method == 'POST':
        bounty_id = request.POST.get('bounty_id')
        bounty = Bounty.objects.get(id=bounty_id)
        session_url = create_stripe_checkout(bounty)
        return HttpResponseRedirect(session_url)

@csrf_exempt
def stripe_checkout_teaming_retainer(request):
    if request.method == 'POST':
        teaming_retainer_id = request.POST.get('teaming_retainer_id')
        teaming_retainer = TeamingRetainer.objects.get(id=teaming_retainer_id)
        session_url = create_stripe_checkout_teaming_retainer(teaming_retainer)
        return HttpResponseRedirect(session_url)
